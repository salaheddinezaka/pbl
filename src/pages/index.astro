---
import { createReader } from "@keystatic/core/reader";
import CmsPageDocument from "../components/CmsPageDocument.astro";
import {
  findPageForRequestPath,
  normalizePath,
  type PageEntry,
} from "../lib/cms-pages";
import keystaticConfig from "../../keystatic.config";

export const prerender = false;

const reader = createReader(process.cwd(), keystaticConfig);
const pageEntries = await reader.collections.pages.all();
const pages = pageEntries.map((entry) => entry.entry as PageEntry);

const page = findPageForRequestPath(pages, normalizePath("/"));

if (!page) {
  Astro.response.status = 404;
}
---

<CmsPageDocument page={page} />
