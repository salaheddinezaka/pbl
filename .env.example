# Required for protected pages: sign the access cookie (use a long random string in production).
ACCESS_COOKIE_SECRET=

# Optional: Netlify Identity JWT secret (legacy HS256 shared secret). If
# present, the content-page gate in middleware verifies the nf_jwt cookie
# alongside the email-form cookie. Not used for /admin — Decap + Git
# Gateway handle admin auth natively.
IDENTITY_JWT_SECRET=

# Optional: Netlify Identity API URL for the widget on /access.
# Example: https://your-site.netlify.app/.netlify/identity
PUBLIC_NETLIFY_IDENTITY_URL=
