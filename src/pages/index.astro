---
import { getCollection } from "astro:content";
import CmsPageDocument from "../components/CmsPageDocument.astro";
import {
  findPageForRequestPath,
  normalizePath,
  type PageEntry,
} from "../lib/cms-pages";

export const prerender = false;

const pageEntries = await getCollection("pages");
const pages: PageEntry[] = pageEntries.map((entry) => ({
  title: entry.data.title,
  urlPath: entry.data.urlPath,
  htmlContent: entry.data.htmlContent,
  headHtml: entry.data.headHtml,
  isProtected: entry.data.isProtected,
  allowedEmails: entry.data.allowedEmails,
}));

const page = findPageForRequestPath(pages, normalizePath("/"));

if (!page) {
  Astro.response.status = 404;
}
---

<CmsPageDocument page={page} />
