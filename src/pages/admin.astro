---
// Serves Decap at /admin — static shell; CMS loads from /admin/config.yml
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex" />
    <link href="/admin/config.yml" type="text/yaml" rel="cms-config-url" />
    <title>Content Manager</title>
  </head>
  <body>
    <!-- Manual init: register iframe preview before CMS starts (so scripts run in preview). -->
    <script is:inline>
      window.CMS_MANUAL_INIT = true;
    </script>
    <script
      is:inline
      src="https://unpkg.com/decap-cms@3.1.2/dist/decap-cms.js"
    />
    <script is:inline src="/admin/decap-pages-preview.js"></script>
  </body>
</html>
